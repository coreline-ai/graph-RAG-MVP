APP_NAME=Simple-Graph-RAG
APP_ENV=development
HOST=0.0.0.0
PORT=8000
TOP_K=10
LOG_LEVEL=INFO

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=graph_rag
POSTGRES_USER=graph_rag
POSTGRES_PASSWORD=graph_rag
POSTGRES_SSLMODE=disable
PGVECTOR_TABLE=chunk_embeddings

NEO4J_URI=bolt://127.0.0.1:8768
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=graph-rag-password
NEO4J_DATABASE=neo4j

CHUNKER_BACKEND=kss
CHUNK_MAX_TOKENS=256
CHUNK_OVERLAP_TURNS=1
CHUNK_MERGE_TIME_GAP_SECONDS=300

EMBEDDING_PROVIDER=local_transformer
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=16

CODEX_PROXY_BASE_URL=http://127.0.0.1:8800
CODEX_MODEL=gpt-5.3-codex
CODEX_TIMEOUT_SECONDS=45

GRAPH_NEIGHBOR_HOPS=1
GRAPH_NEXT_WINDOW=2
DEFAULT_ACCESS_SCOPES=public
